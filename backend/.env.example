# ════════════════════════════════════════════════
#  Caretica Backend — Environment Variables
#  Copy this file to .env and fill in the values
# ════════════════════════════════════════════════

# ── SERVER ──────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app

# ── DATABASE ────────────────────────────────────
# Option A — Local development (SQLite):
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"

# Option B — Production (PostgreSQL via Railway/Supabase/Neon):
# DATABASE_PROVIDER=postgresql
# DATABASE_URL="postgresql://user:password@host:5432/caretica?sslmode=require"

# ── JWT ─────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-string

# ── EMAIL (Gmail App Password) ──────────────────
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM="Caretica <your-gmail@gmail.com>"

# ── STRIPE ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── ANTHROPIC CLAUDE API ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GOOGLE CLOUD VISION (OCR) ────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
